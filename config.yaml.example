---
profiles:
  - profile_1:
      address: "192.168.1.1"
      username: "admin"
      password: "admin"
      timeout_seconds: 5
      poe: 0
      comments:
        Port 1: Port 1
        Port 2: Port 2
        Port 3: Port 3
        Port 4: Port 4
        Port 5: Port 5
        Port 6: Core Switch
  - profile_2:
      address: "192.168.1.2"
      username: "admin"
      password: "admin"
      timeout_seconds: 5
      poll_rate_seconds: 30 # overrides settings.poll_rate_seconds for this profile only
      poe: 1
      comments:
        Port 1: Port 1
        Port 2: Port 2
        Port 3: Port 3
        Port 4: Port 4
  - profile_3:
      profile: v2 # selects the JSON-based dialect (e.g. SKS3200-8E2X); poe: 1 is not
      address: "192.168.1.3" # supported and rejected at startup for profile: v2
      username: "admin"
      password: "admin"
      comments:
        Port 1: Uplink
settings:
  poll_rate_seconds: 10 # default for profiles without their own poll_rate_seconds
  timeout_seconds: 5 # default for profiles without their own timeout_seconds